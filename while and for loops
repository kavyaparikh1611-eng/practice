i=1
while i < 11:
    print(i)
    i+=1

#break statement
i = 1
while i < 10:
  print(i)
  if i == 11:
    break
  i += 1

#continue statement
i = 0
while i < 10:
  i += 1
  if i == 3:
    continue
  print(i)
  
#else statement

i = 1
while i < 10:
  print(i)
  i += 1
else:
  print("i is no longer less than 10")
